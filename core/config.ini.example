[upbx]
address = :5060
daemonize = 0
# secret = <32-char-hex-for-nonce-signing>
# registrations = /var/lib/upbx/registrations
# locality = 4
# emergency = 911
# emergency = 112

# API server (RESP protocol)
[api]
address = :6379
# socket_owner = user:group

# RTP Proxy configuration (requires running udphole instance)
# address: udphole socket address (unix:// or tcp://)
# username/password: optional authentication
[rtpproxy]
address = unix:///var/run/udphole.sock
username = myuser
password = mypass

# [plugin:myplugin]
# exec = /usr/bin/my-plugin-binary

[trunk:mycarrier]
address = udp://sip.example.com:5060
username = myuser
password = mypass
did = 15559876543
# did = 15551234567
cid = 15559876543
# cid_name = My Company
# pattern = ^00(.*)
# replace = \1
# pattern = ^0
# replace = 31
# overflow_timeout = 30
# overflow_strategy = none
# overflow_target =
# user_agent = upbx/0.1.0
# group = 1234
# filter_incoming = 0

[ext:100]
# name = Front desk
secret = my-secret
