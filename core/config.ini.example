[upbx]
listen = 0.0.0.0:5060
daemonize = 0
# secret = <32-char-hex-for-nonce-signing>
# registrations = /var/lib/upbx/registrations
# locality = 4
# emergency = 911
# emergency = 112

# RTP Proxy configuration
# mode: "builtin" (default) or "external"
# address: socket URL for RTPP control protocol
#   - unix:///path/to/socket   (Unix domain socket)
#   - tcp://host:port          (TCP socket)
#   - udp://host:port          (UDP socket)
# ports: RTP port range for relay (default 10000-20000)
# advertise: advertised address for SDP (useful behind NAT)
# supports_tcp_media: 0/1 - for PBX to use when building SDP offers
[rtpproxy]
mode = builtin
address = unix:///var/run/upbx-rtpproxy.sock
ports = 7000-7099
# advertise = 203.0.113.1
supports_tcp_media = 1

# [plugin:myplugin]
# exec = /usr/bin/my-plugin-binary

[trunk:mycarrier]
host = sip.example.com
port = 5060
transport = udp
username = myuser
password = mypass
did = 15559876543
# did = 15551234567
cid = 15559876543
# cid_name = My Company
# pattern = ^00(.*)
# replace = \1
# pattern = ^0
# replace = 31
# overflow_timeout = 30
# overflow_strategy = none
# overflow_target =
# user_agent = upbx/0.1.0
# group = 1234
# filter_incoming = 0

[ext:100]
# name = Front desk
secret = my-secret
