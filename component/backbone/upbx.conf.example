; UPBX example configuration
;
; Copy this file to /etc/upbx.conf and adjust to your needs.
; Run with: upbx daemon -c /path/to/upbx.conf

[upbx]

; Listen addresses (repeatable)
; Clients and peers connect to these addresses.
listen = tcp://:5070
; listen = unix:///var/run/upbx.sock

; Peer addresses (repeatable)
; Other UPBX nodes to connect to for call routing.
; Only one side needs to list the other as a peer;
; the connection is bidirectional once established.
; peer = tcp://192.168.1.10:5070
; peer = unix:///var/run/peer.sock

; Cluster secret
; All nodes in the cluster must share the same secret.
; Used to derive the ed25519 keypair for peer authentication.
cluster_secret = change-me

; User accounts
; Each user section defines a client that can authenticate.
; Provide either a secret (for key derivation) or a pubkey (direct).

[user:alice]
secret = alice-secret

[user:bob]
secret = bob-secret

; Example using a direct public key (32 bytes, hex-encoded):
; [user:carol]
; pubkey = abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
